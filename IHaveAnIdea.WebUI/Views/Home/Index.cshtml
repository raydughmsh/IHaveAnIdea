@model IList<IHaveAnIdea.Business.DTOs.PostDto>
@using IHaveAnIdea.Business.DTOs
@{
    ViewData["Title"] = "Ana Sayfa";
    var categories = ViewBag.Categories as IList<CategoryDto>;
    var selectedCategory = ViewBag.SelectedCategory as int?;
    var search = ViewBag.Search as string;
}

<div class="row">
    <!-- Category Sidebar -->
    <div class="col-md-3">
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">
                <i class="bi bi-grid"></i> Kategoriler
            </div>
            <div class="list-group list-group-flush">
                <a asp-controller="Home" asp-action="Index"
                   class="list-group-item list-group-item-action @(selectedCategory == null && string.IsNullOrEmpty(search) ? "active" : "")">
                    <i class="bi bi-collection"></i> Tümü
                </a>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <a asp-controller="Home" asp-action="Index" asp-route-categoryId="@cat.Id"
                           class="list-group-item list-group-item-action @(selectedCategory == cat.Id ? "active" : "")">
                            @GetCategoryIcon(cat.Name) @cat.Name
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Post Feed -->
    <div class="col-md-9">
        @if (!string.IsNullOrEmpty(search))
        {
            <div class="alert alert-info">
                <i class="bi bi-search"></i> "<strong>@search</strong>" için @Model.Count sonuç bulundu.
                <a asp-controller="Home" asp-action="Index" class="float-end">Temizle</a>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-1"></i>
                <p class="mt-3 fs-5">Henüz gönderi yok.</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">İlk gönderiyi sen paylaş!</a>
                }
            </div>
        }
        else
        {
            @foreach (var post in Model)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary">@post.CategoryName</span>
                            <small class="text-muted">@post.CreatedAt.ToString("dd MMM yyyy, HH:mm")</small>
                        </div>
                        <h5 class="card-title">
                            <a asp-controller="Post" asp-action="Detail" asp-route-id="@post.Id"
                               class="text-decoration-none text-dark">@post.Title</a>
                        </h5>
                        <p class="card-text text-muted">
                            @(post.Content.Length > 200 ? post.Content[..200] + "..." : post.Content)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="bi bi-person-circle"></i> <strong>@post.AuthorName</strong>
                        </small>
                        <div class="d-flex gap-3">
                            <span class="text-muted small">
                                <i class="bi bi-chat"></i> @post.CommentCount
                            </span>
                            <span class="text-muted small @(post.IsLikedByCurrentUser ? "text-danger" : "")">
                                <i class="bi bi-heart@(post.IsLikedByCurrentUser ? "-fill" : "")"></i> @post.LikeCount
                            </span>
                            <a asp-controller="Post" asp-action="Detail" asp-route-id="@post.Id"
                               class="btn btn-sm btn-outline-primary">
                                Oku <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@functions {
    string GetCategoryIcon(string name) => name switch
    {
        "Fikir" => "💡",
        "Öneri" => "📢",
        "Şikayet" => "😤",
        "Duygu" => "❤️",
        _ => "📌"
    };
}
